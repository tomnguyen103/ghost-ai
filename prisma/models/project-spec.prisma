model ProjectSpec {
  id        String   @id @default(cuid())
  projectId String
  creatorId String
  filePath  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@index([creatorId])
}
